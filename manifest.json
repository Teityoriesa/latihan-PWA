{
  "id": "com.moodbite.app",
  "name": "MoodBite - Rekomendasi Makanan",
  "short_name": "MoodBite",
  "description": "Aplikasi cerdas untuk mendapatkan rekomendasi makanan terbaik berdasarkan suasana hati (mood) Anda.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "background_color": "#FFF9F0",
  "theme_color": "#FFD54F",
  "orientation": "portrait",
  "lang": "id",
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "icons": [
