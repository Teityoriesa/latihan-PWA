    },
    {
      "src": "icons/screenshot2.png",
      "sizes": "1887x878",
      "type": "image/png",
      "label": "Hasil Rekomendasi Makanan"
    }
  ],
  "shortcuts": [
    {
      "name": "Cek Mood Hari Ini",
      "short_name": "Mood Check",
      "url": "./index.html",
      "icons": [
        {
          "src": "icons/icon1.png",
          "sizes": "192x192",
          "type": "image/png",
          "purpose": "any"
        },
        {
          "src": "icons/icon2.png",
          "sizes": "512x512",
          "type": "image/png",
          "purpose": "any"
        }
      ]
    }
  ],
  "categories": [
    "lifestyle",
    "food",
    "utilities",
    "note_taking"
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "application/json": [".json"],
        "text/plain": [".txt"]
      },
      "icons": [
        {
          "src": "icons/icon1.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
      "launch_type": "single-client"
    }
  ],
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },
  "share_target": {
    "action": "./index.html",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+moodbite",
      "url": "./index.html?protocol=%s"
    }
  ],
  "prefer_related_applications": false,

  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.moodbite.app",
      "id": "com.moodbite.app"
    },
    {
      "platform": "itunes",
      "url": "https://apps.apple.com/app/moodbite/id0000000000"
    },
    {
      "platform": "webapp",
      "url": "https://moodbite.app/manifest.json"
    }
  ],

  "scope_extensions": [
    {
      "origin": "https://moodbite.app"
    },
    {
      "origin": "https://api.moodbite.app"
    },
    {
      "origin": "https://cdn.moodbite.app"
    }
  ],

  "widgets": [
    {
      "name": "MoodBite Mood Check",
      "short_name": "Mood Check",
      "description": "Cek mood dan dapatkan rekomendasi makanan langsung dari widget.",
